<?xml version="1.0"?>
<!--
/**
 * Standard_SedecoRedondeo
 * Layout: Admin > Sales > Orders > View
 * Agrega el bloque de redondeo SEDECO al panel de totales de la orden.
 */
-->
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <referenceBlock name="order_totals">
            <block class="Standard\SedecoRedondeo\Block\Adminhtml\Sales\Order\Totals\SedecoRounding"
                   name="sedeco_redondeo_order_totals"
                   template="Magento_Sales::order/totals/tax.phtml">
                <action method="initTotals"/>
            </block>
        </referenceBlock>
    </body>
</page>
